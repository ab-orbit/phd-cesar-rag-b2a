# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves reais
# NUNCA commite o arquivo .env com chaves reais!

# OpenAI API Key
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here

# Langfuse (Observability - opcional)
# Obtenha em: https://cloud.langfuse.com/
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Anthropic API Key (se usar Claude - opcional)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# AWS Credentials (se usar Bedrock - opcional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
