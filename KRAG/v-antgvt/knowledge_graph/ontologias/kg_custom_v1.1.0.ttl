@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

kg:Cliente a kg:Biotecnologia,
        kg:EntidadeCandidata ;
    rdfs:label "Cliente"@pt ;
    kg:consome kg:Produto ;
    kgmeta:status kgmeta:Aprovado ;
    prov:wasAttributedTo "TutorialBot" .

kg:Empresa a kg:Biotecnologia,
        kg:EntidadeCandidata ;
    rdfs:label "Empresa"@pt ;
    kg:integra kg:Processos_de_produção ;
    kgmeta:status kgmeta:Aprovado ;
    prov:wasAttributedTo "TutorialBot" .

kg:Fornecedor a kg:Biotecnologia,
        kg:EntidadeCandidata ;
