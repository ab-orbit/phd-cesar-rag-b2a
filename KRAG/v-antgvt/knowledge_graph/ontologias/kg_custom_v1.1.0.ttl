kg:Processo_de_produção a kg:Biotecnologia,
        kg:EntidadeCandidata ;
    rdfs:label "Processo de produção"@pt ;
    kg:recebe kg:Matéria-prima ;
    kgmeta:status kgmeta:Aprovado ;
    prov:wasAttributedTo "TutorialBot" .

<http://phd-cesar-rag/kg_custom_v1.1.0> a prov:Entity ;
    dc:date "2026-03-23" .

kg:Processos_de_produção a kg:Biotecnologia,
