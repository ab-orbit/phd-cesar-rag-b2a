@prefix kg: <http://phd-cesar-rag/kg#> .
@prefix kgmeta: <http://phd-cesar-rag/meta#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

kg:EntidadeCandidata a owl:Class ;
    rdfs:label "Entidade Candidata" ;
    rdfs:comment "Entidades extraidas que ainda não foram aprovadas." .

kgmeta:status a owl:ObjectProperty ;
    rdfs:label "status" .

kgmeta:Candidato a owl:NamedIndividual ;
    rdfs:label "Candidato" .

kgmeta:Confirmado a owl:NamedIndividual ;
    rdfs:label "Confirmado" .

kgmeta:Aprovado a owl:NamedIndividual ;
    rdfs:label "Aprovado" .

kgmeta:Rejeitado a owl:NamedIndividual ;
    rdfs:label "Rejeitado" .
